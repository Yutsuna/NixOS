[
  {
    label = "lock";
    action = "hyprlock";
    text = "Lock";
    keybind = "l";
  }
  {
    label = "logout";
    action = "hyprshutdown";
    text = "Logout";
    keybind = "e";
  }
  {
    label = "shutdown";
    action = "systemctl poweroff";
    text = "Shutdown";
    keybind = "s";
  }
  {
    label = "reboot";
    action = "systemctl reboot";
    text = "Reboot";
    keybind = "r";
  }
]
